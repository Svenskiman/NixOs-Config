;; ── Bar window ─────────────────────────────────────────────
(defwindow bar
    :monitor 0
    :geometry (geometry
        :x "0%"
        :y "8px"
        :width "98%"
        :height "40px"
        :anchor "top center")
    :stacking "fg"
    :exclusive true
    :focusable false

    (box :class "bar"
        :orientation "h"
        :space-evenly false
        "eww bar"))